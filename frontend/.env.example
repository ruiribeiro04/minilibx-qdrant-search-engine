# Backend API URL for REST endpoints
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend AG-UI agent endpoint (full agent for AI Mode)
NEXT_PUBLIC_AGUI_AGENT_URL=http://localhost:8000/api/agent

# AG-UI assist agent endpoint (for Search Assist summaries)
NEXT_PUBLIC_AGUI_ASSIST_URL=http://localhost:8000/api/assist-agent

# Optional. Used by server/agent.py. When unset the agent replies in echo mode.
OPENAI_API_KEY=
