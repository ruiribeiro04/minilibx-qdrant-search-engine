# Qdrant Cloud
QDRANT_URL=https://your-cluster-id.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=docs_search

# Qdrant embedding models (must match what was used during ingestion)
DENSE_MODEL=BAAI/bge-small-en-v1.5
SPARSE_MODEL=Qdrant/bm25
COLBERT_MODEL=colbert-ir/colbertv2.0

# Data directory (relative to project root, or absolute path)
DATA_DIR=data/generated

# OpenAI-compatible LLM (any provider)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o
LLM_ASSIST_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Comma-separated list of documentation modules
DOC_MODULES=getting-started,drawing,events,image,loop,mouse,sync,window,xpm

# GitHub (for source fetching — avoids rate limits)
GITHUB_TOKEN=your-github-personal-access-token